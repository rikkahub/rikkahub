<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:tools="http://schemas.android.com/tools">

  <!--
    Koog's rag-base / embeddings-base Android variants declare minSdk 35, but their code is pure
    Kotlin/Multiplatform (kotlin-stdlib / coroutines / serialization / kotlinx-io only) and uses no
    API-35 platform feature. Override the merge so the app keeps minSdk 26.
  -->
  <uses-sdk tools:overrideLibrary="ai.koog.rag.base, ai.koog.embeddings.base" />

  <uses-permission android:name="android.permission.INTERNET" />
  <uses-permission android:name="android.permission.CAMERA" />
  <uses-permission android:name="android.permission.RECORD_AUDIO" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />
  <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
  <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.WAKE_LOCK" />
  <uses-permission android:name="android.permission.ACCESS_LOCAL_NETWORK" />

  <uses-feature
    android:name="android.hardware.camera"
    android:required="false" />
  <uses-feature
    android:name="android.hardware.camera.autofocus"
    android:required="false" />

  <queries>
    <intent>
      <action android:name="android.intent.action.TTS_SERVICE" />
    </intent>
    <!--
      Package-visibility filter (Android 11+/API 30) for the app-launch tools. list_app enumerates and
      open_app resolves only LAUNCHER-class apps; this <intent> is the narrow, Play-policy-safe
      alternative to QUERY_ALL_PACKAGES (which must NOT be requested on the play flavor).
    -->
    <intent>
      <action android:name="android.intent.action.MAIN" />
      <category android:name="android.intent.category.LAUNCHER" />
    </intent>
  </queries>

  <application
    android:name=".RikkaHubApp"
    android:largeHeap="true"
    android:allowBackup="true"
    android:appCategory="productivity"
    android:dataExtractionRules="@xml/data_extraction_rules"
    android:enableOnBackInvokedCallback="true"
    android:fullBackupContent="@xml/backup_rules"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/app_name"
    android:supportsRtl="true"
    android:theme="@style/Theme.Rikkahub"
    android:usesCleartextTraffic="true"
    tools:targetApi="33">
    <activity
      android:name=".ui.activity.SafeModeActivity"
      android:exported="false"
      android:label="@string/title_activity_safe_mode"
      android:theme="@style/Theme.Rikkahub" />
    <activity
      android:name=".RouteActivity"
      android:configChanges="keyboardHidden|orientation|screenSize"
      android:exported="true"
      android:importantForAutofill="noExcludeDescendants"
      android:theme="@style/Theme.Rikkahub"
      android:windowSoftInputMode="adjustResize">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />

        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
      <intent-filter>
        <action android:name="android.intent.action.SEND" />

        <category android:name="android.intent.category.DEFAULT" />

        <data android:mimeType="text/plain" />
      </intent-filter>
      <intent-filter>
        <action android:name="android.intent.action.PROCESS_TEXT" />

        <category android:name="android.intent.category.DEFAULT" />

        <data android:mimeType="text/plain" />
      </intent-filter>

      <meta-data
        android:name="android.app.shortcuts"
        android:resource="@xml/shortcuts" />
    </activity>
    <activity
      android:name=".ui.activity.ShortcutHandlerActivity"
      android:exported="true"
      android:theme="@android:style/Theme.Translucent.NoTitleBar">
      <intent-filter>
        <action android:name="android.intent.action.VIEW" />

        <category android:name="android.intent.category.DEFAULT" />

        <data
          android:host="shortcut"
          android:scheme="rikkahub" />
      </intent-filter>
    </activity>
    <activity
      android:name="com.yalantis.ucrop.UCropActivity"
      android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

    <service
      android:name=".service.WebServerService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="local web server for LLM chat UI" />
    </service>

    <service
      android:name=".service.A2aServerService"
      android:exported="false"
      android:foregroundServiceType="specialUse">
      <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="local A2A JSON-RPC server for assistant access" />
    </service>

    <!--
      dataSync (not specialUse): an LLM SSE stream is semantically a network data-sync task, which
      is exactly what dataSync documents. It needs no PROPERTY_SPECIAL_USE_FGS_SUBTYPE justification
      and keeps generation decoupled from the web-server's special-use entry. Android 14+ imposes a
      ~6h/day cumulative dataSync budget. A single SSE read is bounded to ~120s (Part-B streaming
      read timeout), but an agentic tool/MCP/search loop can chain many such reads and run far longer;
      the service lives for the whole loop and stops on the 1->0 generation edge, well within the
      daily budget for normal use. The WakeLock is renewed on streaming progress so a long live loop
      keeps the CPU awake (see GenerationForegroundService.WAKE_LOCK_TIMEOUT_MS).
    -->
    <service
      android:name=".service.GenerationForegroundService"
      android:exported="false"
      android:foregroundServiceType="dataSync" />

    <!--
      On-device UI-automation accessibility service. Inert until the user enables it in system
      accessibility settings. It reads the screen of other apps AND acts on it: tap, type, scroll,
      and global navigation (Back/Home/Recents) may occur, each gated by the user-granted capability
      scope. Actions are issued as node accessibility actions and performGlobalAction, never raw
      screen-point gesture dispatch (design D1), so the config grants no canPerformGestures. The
      floating STOP kill-switch is a TYPE_ACCESSIBILITY_OVERLAY granted with the service, so no
      SYSTEM_ALERT_WINDOW permission is needed.
    -->
    <service
      android:name=".service.automation.AccessibilityRuntime"
      android:exported="false"
      android:label="@string/automation_a11y_service_label"
      android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
      <intent-filter>
        <action android:name="android.accessibilityservice.AccessibilityService" />
      </intent-filter>
      <meta-data
        android:name="android.accessibilityservice"
        android:resource="@xml/accessibility_service_config" />
    </service>

    <provider
      android:name="androidx.core.content.FileProvider"
      android:authorities="${applicationId}.fileprovider"
      android:exported="false"
      android:grantUriPermissions="true">
      <meta-data
        android:name="android.support.FILE_PROVIDER_PATHS"
        android:resource="@xml/file_paths" />
    </provider>
    <provider
      android:name="androidx.startup.InitializationProvider"
      android:authorities="${applicationId}.androidx-startup"
      android:exported="false"
      tools:node="merge">
      <meta-data
        android:name="androidx.work.WorkManagerInitializer"
        android:value="androidx.startup"
        tools:node="remove" />
    </provider>
  </application>

</manifest>
