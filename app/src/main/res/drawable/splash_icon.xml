<?xml version="1.0" encoding="utf-8"?>
<!-- Splash icon: the Poci robot as a single alpha-shaped glyph, tinted per theme. The tint
     (@color/splash_icon_tint) resolves light/dark via values / values-night, so the robot is dark on the
     light splash and light on the dark splash — following the device theme with one asset. -->
<bitmap xmlns:android="http://schemas.android.com/apk/res/android"
    android:src="@drawable/splash_robot"
    android:gravity="center"
    android:tint="@color/splash_icon_tint"
    android:tintMode="src_in" />
