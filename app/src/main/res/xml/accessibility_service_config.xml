<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuration for AccessibilityRuntime UI automation.

  The service both READS and ACTS on the screen of other apps: window content is retrieved
  (canRetrieveWindowContent) to advance the monotonic stateSeq, and write verbs are dispatched —
  tap (node ACTION_CLICK), type (ACTION_SET_TEXT), scroll (ACTION_SCROLL_*), and global navigation
  (performGlobalAction BACK/HOME/RECENTS). NO canPerformGestures here on purpose: actions are issued
  as node accessibility actions and performGlobalAction, never as raw screen-point gesture dispatch
  (design D1). Every action is still gated by the user-granted capability scope and the mandatory
  STOP kill-switch. flagRetrieveInteractiveWindows gives multi-window awareness (app + system
  dialogs) so permission/system UI is observable.

  The service is inert until the user explicitly enables it in system accessibility settings.
-->
<accessibility-service xmlns:android="http://schemas.android.com/apk/res/android"
    android:description="@string/automation_a11y_service_description"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="100" />
