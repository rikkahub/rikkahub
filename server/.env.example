PERRY_ENV=development
PERRY_HOST=127.0.0.1
PERRY_PORT=8787
PERRY_DATABASE_URL=sqlite+aiosqlite:///./data/perry.db
PERRY_BOOTSTRAP_TOKEN=change-me-to-a-long-random-token
PERRY_TOKEN_PEPPER=change-me-to-an-independent-random-secret
PERRY_PUBLIC_BASE_URL=http://127.0.0.1:8787
PERRY_API_VERSION=0.1.0
PERRY_MIN_CLIENT_VERSION=2.4.1

# MinIO is server-side only (Perry proxies all file bytes).
# Android never receives MinIO credentials or presigned URLs.
# Use localhost/private network endpoint; do not expose MinIO to phones.
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=haruhomedev
MINIO_SECURE=false

MONEL_BASE_URL=http://127.0.0.1:7890
MONEL_AUTH_KEY=
