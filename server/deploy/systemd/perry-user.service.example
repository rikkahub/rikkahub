[Unit]
Description=Haruhome Perry API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/src/haruhome/server
EnvironmentFile=%h/src/haruhome/server/.env
ExecStart=%h/src/haruhome/server/.venv/bin/uvicorn perry_server.main:app --host 0.0.0.0 --port 8787 --workers 1
Restart=on-failure
RestartSec=5
TimeoutStopSec=30
KillMode=mixed
UMask=0077

[Install]
WantedBy=default.target
